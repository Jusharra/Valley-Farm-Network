# Vite exposes env vars prefixed with VITE_ to the client
# Copy this file to .env and fill in your values

# API
VITE_API_URL=http://localhost:3000

# Stripe Connect
# Get these from dashboard.stripe.com → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret — from Stripe Dashboard → Developers → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# Platform fee charged on each transaction (e.g. 0.05 = 5%)
# Super admin can override this per merchant via DB, this is the global default
STRIPE_PLATFORM_FEE_PERCENT=0.05

# One-time listing fee in cents (e.g. 2500 = $25.00)
STRIPE_LISTING_FEE_CENTS=2500

# Farmer platform subscription tiers (monthly, in cents)
# Basic — farm page, product listings, shareable link
STRIPE_TIER_BASIC_CENTS=3900
STRIPE_TIER_BASIC_PRICE_ID=price_...

# Pro — everything in Basic + customer subscriptions + delivery tools
STRIPE_TIER_PRO_CENTS=6900
STRIPE_TIER_PRO_PRICE_ID=price_...

# Supabase
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth (Supabase handles this — add your own JWT secret only if using custom auth)
# JWT_SECRET=your-secret-here
