# Vite exposes env vars prefixed with VITE_ to the client
# Copy this file to .env and fill in your values

# API
VITE_API_URL=http://localhost:3000

# Stripe Connect
# Get these from dashboard.stripe.com → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Stripe Connect hosted onboarding URL — from Stripe Dashboard → Connect → Account management
# Share this link with farmers so they can connect their Stripe Express account
VITE_STRIPE_CONNECT_ONBOARDING_URL=https://connect.stripe.com/d/setup/e/...

# Webhook secret — from Stripe Dashboard → Developers → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_
# One-time listing fee — standalone option for farmers who don't want a subscription
# Includes: farm page, product listings, shareable link (no subscriptions or delivery tools)
STRIPE_LISTING_FEE_CENTS=2500
STRIPE_LISTING_FEE_PRICE_ID=price_...

# Farmer platform subscription tiers (monthly, in cents)
# Seed — farm page, up to 10 products, shareable link
STRIPE_TIER_SEED_CENTS=3900
STRIPE_TIER_SEED_PRICE_ID=price_...

# Growth — everything in Seed + customer subscriptions + delivery zones + analytics
STRIPE_TIER_GROWTH_CENTS=7900
STRIPE_TIER_GROWTH_PRICE_ID=price_...

# Network Pro — everything in Growth + driver network + homepage boosts + priority support
STRIPE_TIER_PRO_CENTS=12900
STRIPE_TIER_PRO_PRICE_ID=price_...

# Supabase
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL — used by Edge Functions to build return_url after Stripe redirects
# Development: http://localhost:5173  |  Production: https://yourdomain.com
APP_URL=http://localhost:5173

# Auth (Supabase handles this — add your own JWT secret only if using custom auth)
# JWT_SECRET=your-secret-here
